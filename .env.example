NODE_ENV = development
PORT = 8080

# Database
MONGOURI = mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# CORS - comma separated origins for multiple (e.g. http://localhost:5173,https://yourdomain.com)
CORS_ORIGIN = http://localhost:5173

# Client URL - used for email invite links
CLIENT_URL = http://localhost:5173

# JWT
JWT_SECRET = your_jwt_secret_here

# SMTP Mail
SMTP_MAIL = your_email@gmail.com
SMTP_PASSWORD = your_app_password_here
